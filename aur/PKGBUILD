# Maintainer: Megaproaktiv <silberkopf@gmail.com>
pkgname=ltail
pkgver=0.3.0
pkgrel=1
pkgdesc="Fast, multipurpose tool for AWS CloudWatch Logs"
arch=('i686' 'x86_64' 'armv6h' 'armv7h')
provides=('ltail')
url="https://github.com/megaproaktiv/$pkgname"
license=('MIT')
makedepends=('go' 'git')
source=("https://github.com/megaproaktiv/$pkgname/archive/v$pkgver.tar.gz")
md5sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  go build -o ltail .
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  install -Dm755 ltail "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
